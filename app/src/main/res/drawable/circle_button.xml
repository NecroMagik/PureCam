<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Нижний слой - основной цвет Material You -->
    <item>
        <shape android:shape="oval">
            <solid android:color="?attr/colorPrimary" />
            <size
                android:width="72dp"
                android:height="72dp" />
        </shape>
    </item>

    <!-- Верхний слой - вторичный цвет Material You -->
    <item
        android:bottom="7dp"
        android:left=  "7dp"
        android:right= "7dp"
        android:top=   "7dp">
        <shape android:shape="oval">
            <solid android:color="?attr/colorSecondaryContainer" />
        </shape>
    </item>
</layer-list>