<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Сетка (поверх превью) -->
    <View
        android:id="@+id/gridView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/grid_overlay"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Верхняя панель -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#80000000"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnLens"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="📷"
            android:textSize="20sp"
            android:paddingHorizontal="8dp" />

        <Button
            android:id="@+id/btnRaw"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="RAW"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="⚙️"
            android:textSize="24sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnFlash"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="⚡"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnGrid"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="⊞"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnHdr"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="HDR"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDev"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="👨‍💻"
            android:textSize="24sp" />

    </LinearLayout>

    <!-- Панель форматов -->
    <LinearLayout
        android:id="@+id/aspectPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topPanel">

        <TextView
            android:id="@+id/aspect4_3"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="4:3"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:background="#FF6200EE" />

        <TextView
            android:id="@+id/aspect1_1"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="1:1"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/aspect16_9"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="16:9"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/aspectFull"
            android:layout_width="64dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Full"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Панель качества JPEG -->
    <LinearLayout
        android:id="@+id/qualityPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/aspectPanel">

        <TextView
            android:id="@+id/qualityHigh"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Высокое"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/qualityMedium"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Среднее"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/qualityLow"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Низкое"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Панель обработки -->
    <LinearLayout
        android:id="@+id/processingPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/qualityPanel">

        <TextView
            android:id="@+id/processNatural"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Натуральный"
            android:textColor="@android:color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/processNeutral"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Нейтральный"
            android:textColor="@android:color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/processVivid"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Насыщенный"
            android:textColor="@android:color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/processPortrait"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Портрет"
            android:textColor="@android:color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/processLandscape"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Пейзаж"
            android:textColor="@android:color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/processMonochrome"
            android:layout_width="56dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Монохром"
            android:textColor="@android:color/white"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Панель зума (плавный слайдер) -->
    <SeekBar
        android:id="@+id/zoomSlider"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"
        android:progress="50"
        android:max="100"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/zoomValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="1x"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:background="#80000000"
        android:padding="4dp"
        app:layout_constraintBottom_toTopOf="@+id/zoomSlider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Кнопка съемки -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/captureButton"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/circle_button"
        android:text=""
        android:textSize="32sp"
        app:layout_constraintBottom_toTopOf="@+id/zoomSlider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Текст статуса -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:padding="4dp"
        android:text="Готов"
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:background="#80000000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/processingPanel" />

</androidx.constraintlayout.widget.ConstraintLayout>